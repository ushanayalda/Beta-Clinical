{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clinical-pathway.local/case-system-v2.0.0/schemas/hold-report.schema.json",
  "title": "Clinical Pathway machine-readable HOLD report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "response_type",
    "operation",
    "case_id",
    "status",
    "generation_performed",
    "blocking_reasons",
    "missing_fields",
    "conflicts",
    "unsupported_claims",
    "next_authorised_action"
  ],
  "$defs": {
    "semver": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "date": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "case_id": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^CP-P[0-9]{3}-C[0-9]{3}$"
    },
    "hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "nonempty": {
      "type": "string",
      "minLength": 1
    }
  },
  "properties": {
    "schema_version": {
      "const": "2.0.0"
    },
    "response_type": {
      "const": "HOLD_REPORT"
    },
    "operation": {
      "enum": [
        "IMPORT",
        "PREFLIGHT",
        "BUILD_CASE",
        "REPAIR_CASE",
        "BUILD_REASONING_LAYER",
        "REPAIR_REASONING_LAYER",
        "AUDIT",
        "EXPORT"
      ]
    },
    "case_id": {
      "$ref": "#/$defs/case_id"
    },
    "status": {
      "enum": [
        "hold",
        "blocked"
      ]
    },
    "generation_performed": {
      "const": false
    },
    "blocking_reasons": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "missing_fields": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "conflicts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "unsupported_claims": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "next_authorised_action": {
      "$ref": "#/$defs/nonempty"
    }
  }
}
